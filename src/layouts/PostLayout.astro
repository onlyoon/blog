---
import "../styles/post-style.css";
import MaxWidthWrapper from "../components/MaxWidthWrapper.astro";
import "../styles/global.css";
import type { MarkdownLayoutProps } from "astro";
import Navigation from "../components/Navigation.astro";
// import Graph from "../components/Graph.astro";

type Props = MarkdownLayoutProps<{
  title: string;
  author: string;
  date: string;
  pubDate: string;
  description: string;
  category: string;
}>;

// 블로그 포스트 파일들을 모두 가져온다 (eager: true로 즉시 import)
const getPosts = import.meta.glob("../pages/blog/*.md", {
  eager: true,
}) as Record<
  string,
  {
    url: string;
    frontmatter: any;
    rawContent: () => string;
  }
>;

// 객체의 value만 배열로 변환 (각 포스트 정보)
const posts = Object.values(getPosts);

// console.log("posts", posts);

async function extractLinks() {
  const currentUrl = Astro.url.pathname;
  const currentPost = posts.find((post) => post.url === currentUrl);

  if (!currentPost) return [];

  const content = currentPost?.rawContent ? currentPost.rawContent() : "";

  const linkPattern = /\[([^\]]+)\]\(([^)]+)\)/g;
  const links = [];
  let match: RegExpExecArray | null;

  while ((match = linkPattern.exec(content)) !== null) {
    const text = match[1]; // 링크 텍스트
    const href = match[2]; // 링크 URL

    if (href.startsWith("/blog/") || href.endsWith(".md")) {
      let normalizedHref = href;
      const slug = normalizedHref.split("/").filter(Boolean).pop() || "";
      const linkedPost = posts.find((post) => {
        return post.url + ".md" === normalizedHref;
      });
      const url = linkedPost?.url || "";
      const desc = linkedPost?.frontmatter?.description || "";

      links.push({
        title: text,
        url: href,
        desc: desc,
      });
    }
  }

  return links;
}

const links = await extractLinks();

const { frontmatter } = Astro.props;
---

<html>
  <head>
    <!-- ... -->
    <meta charset="utf-8" />
  </head>
  <!-- ... -->
  <body>
    <Navigation />
    <MaxWidthWrapper className="flex flex-col lg:flex-row h-fit">
      <header
        id="blog-header"
        class="flex-5/12 pt-12 lg:sticky static lg:pl-0 pl-4 pr-4 h-fit top-14"
      >
        <h1 class="font-bold pb-4 whitespace-pre-wrap">{frontmatter.title}</h1>
        <div class="flex flex-row overflow-auto">
          <div class="w-full flex items-center justify-between mb-2 rounded-xl">
            <p class="text-sm text-gray-500">{frontmatter.author}</p>
            <p class="text-sm text-gray-500">{frontmatter.pubDate}</p>
          </div>
        </div>
        <div class="flex flex-col gap-4 mb-12">
          <div class="w-full flex justify-start">
            <p class="text-lg font-bold">Related Posts</p>
          </div>
          <div
            class="w-full flex items-center justify-center border-3 border-dashed rounded-2xl"
          >
            <!-- <Graph
              links={links}
              currentPost={{
                title: frontmatter.title,
                url: Astro.url.pathname,
                desc: frontmatter.description,
              }}
              className="min-w-96 w-full h-72"
            /> -->
          </div>
        </div>
      </header>

      <!-- 메인 콘텐츠 영역 - 개선된 간격과 타이포그래피 -->

      <main
        id="markdown-content"
        class="flex-7/12 flex flex-col prose prose-base sm:prose-lg md:prose-xl lg:prose-lg xl:prose-xl
         prose-gray dark:prose-invert max-w-none leading-relaxed"
      >
        <div
          class="prose-headings:scroll-mt-24 lg:pt-12 pt-4 px-4 lg:px-0 mb-12"
        >
          <slot />
        </div>
      </main>
    </MaxWidthWrapper>
  </body>
</html>

<script>
  const content = document.getElementById("markdown-content");

  // 모든 h2 태그를 감싸는 div 추가
  const headings = content?.querySelectorAll("h2");

  headings?.forEach((heading) => {
    const wrapper = document.createElement("div");
    wrapper.classList.add("heading-wrapper");

    heading?.parentNode?.insertBefore(wrapper, heading);
    wrapper.appendChild(heading);

    // 이후 관련된 내용도 포함 가능
  });
</script>
