---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import MaxWidthWrapper from '../../components/MaxWidthWrapper.astro';
import Navigation from '../../components/Navigation.astro';
import CherryTree3D from '../../components/CherryTree3D';
import { getMenu } from '../../utils/get/menu';
import type { Locale } from '../../i18n/translation';

const currentLocale: Locale = 'kr';
const menuItems = getMenu(currentLocale);
---

<Layout>
  <Navigation menuItems={menuItems} currentLocale={currentLocale} />
  <MaxWidthWrapper>
    <div class="py-12">
      <!-- 헤더 섹션 -->
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-custom-text mb-4">
          Cherry blossom
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
          Interactive 3D Cherry blossom simulation created with Three.js.
          featuring Ghibli-style assets rendered with custom GLSL shaders.
        </p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span
            class="px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800 border border-purple-200 dark:bg-purple-900/30 dark:text-purple-300 dark:border-purple-700"
          >
            Three.js
          </span>
          <span
            class="px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 border border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-700"
          >
            TypeScript
          </span>
          <span
            class="px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 border border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700"
          >
            GLSL Shaders
          </span>
        </div>
      </div>

      <!-- 3D 뷰어 -->
      <div class="mb-8 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
        <CherryTree3D client:load />
      </div>
    </div>
  </MaxWidthWrapper>
</Layout>


