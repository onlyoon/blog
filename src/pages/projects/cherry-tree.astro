---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import CherryTree3D from '../../components/CherryTree3D';
import { getMenu } from '../../utils/get/menu';
import type { Locale } from '../../i18n/translation';

const currentLocale: Locale = 'kr';
const menuItems = getMenu(currentLocale);
---

<Layout title="Cherry Blossom 3D">
  <!-- Preload and pre-render calligraphy font to prevent layout shifts (FOUT) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&display=swap" rel="stylesheet" />

  <div class="relative w-screen h-screen overflow-hidden bg-white dark:bg-slate-950">
    <!-- 네비게이션 (3D 씬 위에 얹음) -->
    <div class="absolute inset-x-0 top-0 z-50">
      <Navigation menuItems={menuItems} currentLocale={currentLocale} />
    </div>

    <!-- 3D 벚꽃 나무 (전체 화면) -->
    <div class="absolute inset-0 z-0 w-full h-full">
      <CherryTree3D client:load />
    </div>
  </div>
</Layout>
