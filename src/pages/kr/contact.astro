---
import '../../styles/global.css';
import type { Locale } from '../../i18n/translation';
import MaxWidthWrapper from '../../components/MaxWidthWrapper.astro';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { getMenu } from '../../utils/get/menu';

const currentLocale: Locale = 'kr';
const menuItems = getMenu(currentLocale);
---

<Layout>
  <Navigation menuItems={menuItems} currentLocale={currentLocale} />
  <MaxWidthWrapper className="flex flex-col h-fit">
    <header
      id="frontend-header"
      class="flex-5/12 pt-12 static pl-4 pr-4 h-fit top-14"
    >
      <p class="text-custom-text font-bold text-5xl pb-4">Contact</p>
      <div class="flex flex-row">
        <div class="w-full flex items-center justify-between mb-2 rounded-xl">
          <div class="flex flex-row items-center gap-4">
            <!-- <Computer3D client:load /> -->
            <!-- <p class="text-custom-text font-bold text-xl">Let's Connect</p> -->
          </div>
        </div>
      </div>
      <div class="pb-4">
        <p class="text-custom-text">
          이메일이나 소셜 채널을 통해 편하게 연락해주세요. 새로운 연결을 항상
          환영합니다!
        </p>
      </div>
    </header>
    <div class="flex-7/12 flex flex-col gap-4 pt-12 pb-12"></div>
  </MaxWidthWrapper>
</Layout>
